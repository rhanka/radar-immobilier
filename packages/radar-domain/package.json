{
  "name": "@radar/domain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Neutral domain types and versioned Zod schemas for radar-immobilier (Signal, Lot, Opportunity, Score, SourceDocument, Constraint).",
  "license": "UNLICENSED",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts"
  },
  "scripts": {
