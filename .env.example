# Copy to `.env` and fill in. Never commit `.env`.

# ── Postgres (dev) ─────────────────────────────────────────────────────
POSTGRES_USER=radar
POSTGRES_PASSWORD=changeme-dev-only
POSTGRES_DB=radar
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Object storage (MinIO local, Scaleway in prod) ────────────────────
S3_ENDPOINT=http://minio:9000
S3_REGION=fr-par
S3_BUCKET=radar-immobilier-raw
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Scraping-document store (SCW `radar-immobilier-docs` in prod) ──────
# Dedicated bucket for raw scraped documents (PV, avis, zonage…) collected by
# SourceAdapters. Each SCRAPE_S3_* falls back to the corresponding S3_* above
# when absent, so local dev uses MinIO automatically (no config needed).
# In production, set these to the Scaleway Object Storage bucket credentials
# (Object Storage scoped keys, fr-par region) — keys provided out-of-repo by
# the owner. NEVER commit real secrets here (names only).
#
#   Bucket:   radar-immobilier-docs
#   Endpoint: https://s3.fr-par.scw.cloud
#   Region:   fr-par
#   forcePathStyle: false (SCW supports virtual-hosted style)
SCRAPE_S3_ENDPOINT=
SCRAPE_S3_REGION=
SCRAPE_S3_BUCKET=
SCRAPE_S3_ACCESS_KEY=
SCRAPE_S3_SECRET_KEY=
SCRAPE_S3_FORCE_PATH_STYLE=

# ── LLM providers (filled per developer; never commit) ────────────────
# Powers the ÉV9 chat (real @sentropic/llm-mesh streaming) AND the optional
# semantic mention extraction (RADAR_LLM_EXTRACTION below). Both read these keys
# through the SAME shared mesh (api/src/services/chat/mesh-runtime.ts). Set at
# least one key for a provider to be reachable; otherwise the chat reports "no
# provider configured" and semantic extraction stays a no-op. GEMINI_API_KEY and
# GOOGLE_API_KEY are both accepted for the Gemini provider.
#
# radar-dev shortcut: these keys (ANTHROPIC/OPENAI/MISTRAL/GEMINI/COHERE) already
# live in `../sentropic/.env.prod`. To run the LLM paths locally, source that file
# into the api process env — e.g. add it to the api service's `env_file:` in the
# dev compose, or `set -a; . ../sentropic/.env.prod; set +a` before starting the
# api. NEVER commit that file or its values here (names only below).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# Optional semantic (LLM-backed) graphify mention extraction. OFF by default.
# Set to 1 — together with at least one provider key above — to augment the
# deterministic extraction on unstructured docs via @sentropic/llm-mesh. Left at
# 0, radar runs deterministic-only and never reaches a provider (CI stays offline).
RADAR_LLM_EXTRACTION=0

# ── Auth / mail ────────────────────────────────────────────────────────
WEBAUTHN_ORIGIN=http://localhost:5301
WEBAUTHN_RP_ID=localhost
MAILDEV_SMTP_HOST=maildev
MAILDEV_SMTP_PORT=1025

# ── Obscura sidecar ────────────────────────────────────────────────────
OBSCURA_CDP_URL=http://obscura:9222

# ── Reconciliation studio write gate (ontology write-core) ─────────────
# Shared secret that unlocks accept / reject / set_status in the studio. Empty ⇒
# the POST /api/ontology/:city/patch route is fail-closed (401) and the studio
# stays read-only. Set ONE value here: the dev compose feeds it to BOTH the api
# (RADAR_ONTOLOGY_WRITE_TOKEN) and the browser bundle the UI exposes as
# VITE_RADAR_ONTOLOGY_WRITE_TOKEN, so the two always match — no separate VITE_
# value to keep in sync. Any non-empty string works for local dev, e.g.
# dev-write-token. Never commit a real secret.
RADAR_ONTOLOGY_WRITE_TOKEN=

# ── Dev URLs ───────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8801
UI_BASE_URL=http://localhost:5301
VITE_API_BASE_URL=http://localhost:8801
