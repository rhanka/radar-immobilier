{
  "name": "@radar/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Radar-immobilier API — Hono server on Node 24 with Postgres (Drizzle) and S3-compatible object storage.",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@hono/node-server": "^1.12.0",
    "@radar/domain": "*",
    "@radar/sources": "*",
    "@sentropic/chat-core": "^0.1.2",
    "@sentropic/geo": "^0.1.1",
    "@sentropic/geo-sources-americas": "^0.1.1",
    "@sentropic/graphify": "^0.10.0",
    "@sentropic/h2a": "^0.26.1",
    "@sentropic/llm-mesh": "^0.1.2",
    "drizzle-orm": "^0.32.0",
    "hono": "^4.5.0",
    "jose": "^6.2.3",
    "nodemailer": "^7.0.0",
    "pg": "^8.12.0",
    "pino": "^9.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.0",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.23.0",
    "tsx": "^4.16.0",
    "typescript": "5.4.5",
    "vitest": "^1.6.0"
  }
}
